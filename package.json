{
  "name": "ng-simple-state",
  "version": "22.0.4",
  "description": "Simple state management in Angular with only Services and Signal.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nigrosimone/ng-simple-state.git"
  },
  "keywords": [
    "angular",
    "state",
    "rxjs",
    "signal",
    "webmcp",
    "state-management"
  ],
  "author": "Simone Nigro <nigro.simone@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nigrosimone/ng-simple-state/issues"
  },
  "homepage": "https://github.com/nigrosimone/ng-simple-state",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:lib": "ng build ng-simple-state",
    "test": "ng test",
    "test:schematics": "tsc -p projects/ng-simple-state/schematics/tsconfig.schematics.json && xcopy /E /I /Y projects\\ng-simple-state\\schematics\\store\\files projects\\ng-simple-state\\schematics\\out\\store\\files && jasmine projects/ng-simple-state/schematics/out/store/index.spec.js",
    "lint": "ng lint",
    "docs": "typedoc --out docs projects/ng-simple-state/src/public-api.ts --readme README.md",
    "docs:watch": "typedoc --watch --out docs projects/ng-simple-state/src/public-api.ts"
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "lodash.isequal": "^4.5.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "^22.0.0",
    "@angular-devkit/schematics": "^22.0.0",
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@schematics/angular": "^22.0.0",
    "@types/jasmine": "^6.0.0",
    "@types/lodash.isequal": "^4.5.8",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine": "^6.3.0",
    "jasmine-core": "^6.3.0",
    "jasmine-spec-reporter": "^7.0.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "ng-packagr": "^22.0.0",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
